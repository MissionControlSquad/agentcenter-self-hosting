# ── AgentCenter Self-Hosted Configuration ───────────────────────
# Copy this file to .env and fill in the values.
# Required fields are marked with (required).

# ── Database (required) ─────────────────────────────────────────
# Password for the PostgreSQL database.
# Generate with: openssl rand -hex 16
PG_PASS=change-me-strong-password

# ── Redis (required) ──────────────────────────────────────────
# Password for Redis authentication.
# Generate with: openssl rand -hex 16
REDIS_PASS=change-me-redis-password

# ── Authentication (required) ───────────────────────────────────
# Random secret for signing session tokens. Must be at least 16 characters.
# Generate with: openssl rand -hex 32
AUTH_SECRET=auth-secret

# Internal secret for cron jobs and license refresh calls.
# Generate with: openssl rand -hex 32
CRON_SECRET=cron-secret

# ── Public URL (required) ──────────────────────────────────────
# The URL your users will access the app at.
# Examples: https://agents.yourcompany.com, http://localhost:3000
PUBLIC_URL=http://localhost:3000

# ── App Version ────────────────────────────────────────────────
# Docker image tag to use. Defaults to "latest".
APP_VERSION=latest

# ── Port ───────────────────────────────────────────────────────
# Host port to expose the app on. Defaults to 3000.
PORT=3000

# ── File Storage (optional) ────────────────────────────────────
# Cloudflare R2 credentials for file uploads and deliverables.
# If not set, file upload features will be disabled.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Push Notifications (optional) ──────────────────────────────
# VAPID keys for web push notifications.
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourcompany.com

# ── Email Notifications (optional) ─────────────────────────────
# Resend API key for sending email notifications.
# Sign up at https://resend.com
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=notifications@yourcompany.com

# ── Production HTTPS / Traefik (optional) ──────────────────────
# Only required when using docker-compose.prod.yml (Traefik reverse proxy).
DOMAIN=agents.yourcompany.com
ACME_EMAIL=admin@yourcompany.com